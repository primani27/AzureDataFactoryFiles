{
	"name": "ADE_DFSource",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DF_SourceDL",
						"type": "DatasetReference"
					},
					"name": "ADEDFSource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DEstinationETLDL",
						"type": "DatasetReference"
					},
					"name": "ADEETLDestination"
				}
			],
			"transformations": [
				{
					"name": "SelectColumn"
				},
				{
					"name": "SelectRowsWhereFilter"
				},
				{
					"name": "SplitDate1"
				},
				{
					"name": "SumAggregrate"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Sales Person} as string,",
				"          Geo as string,",
				"          Product as string,",
				"          Ship_Date as date,",
				"          Amount as short,",
				"          Boxes as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> ADEDFSource",
				"ADEDFSource select(mapColumn(",
				"          {Sales Person},",
				"          Product,",
				"          Ship_Date,",
				"          Boxes",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> SelectColumn",
				"SelectColumn filter({Sales Person} != 'SP01') ~> SelectRowsWhereFilter",
				"SelectRowsWhereFilter split(Ship_Date==toDate('04-07-2022','dd-MM-yyyy'),",
				"     Ship_Date==toDate('05-07-2022','dd-MM-yyyy'),",
				"     disjoint: false) ~> SplitDate1@(Date1, Date2)",
				"SplitDate1@Date1 aggregate(groupBy({Sales Person}),",
				"     Boxes = sum(Boxes)) ~> SumAggregrate",
				"SumAggregrate sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ADEETLDestination"
			]
		}
	}
}